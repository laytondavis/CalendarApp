<Page x:Class="CalendarApp.Presentation.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:CalendarApp.Presentation"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:um="using:Uno.Material"
      NavigationCacheMode="Required"
      Background="{ThemeResource BackgroundBrush}">

    <Grid x:Name="RootGrid"
          utu:SafeArea.Insets="VisibleBounds"
          ManipulationCompleted="OnCalendarSwipeCompleted">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top Navigation Bar -->
        <utu:NavigationBar Content="{Binding Title}" />

        <!-- Calendar Mode + View Type Selectors + Actions -->
        <Grid Grid.Row="1" Padding="16,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Left: Calendar mode dropdown + View type dropdown -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <ComboBox SelectedIndex="{Binding SelectedCalendarModeIndex, Mode=TwoWay}"
                          MinWidth="110" VerticalAlignment="Center">
                    <ComboBoxItem Content="Gregorian" />
                    <ComboBoxItem Content="Julian" />
                    <ComboBoxItem Content="Biblical" />
                </ComboBox>
                <ComboBox SelectedIndex="{Binding SelectedViewTypeIndex, Mode=TwoWay}"
                          MinWidth="90" VerticalAlignment="Center">
                    <ComboBoxItem Content="Day" />
                    <ComboBoxItem Content="Week" />
                    <ComboBoxItem Content="Month" />
                    <ComboBoxItem Content="Year" />
                    <ComboBoxItem Content="Agenda" />
                </ComboBox>
            </StackPanel>

            <!-- Right: Today + Sync + Settings -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button Content="Today"
                        Command="{Binding TodayCommand}"
                        Style="{StaticResource FilledTonalButtonStyle}" />

                <!-- Sync Button (visible when signed in to Google) -->
                <Button Command="{Binding SyncCommand}"
                        Style="{StaticResource IconButtonStyle}"
                        ToolTipService.ToolTip="{Binding SyncStatusText}"
                        Visibility="{Binding IsSignedIn, Converter={StaticResource BoolToVisibilityConverter}}">
                    <FontIcon Glyph="&#xE895;" FontSize="18" />
                </Button>

                <!-- Settings Button -->
                <Button Command="{Binding SettingsCommand}"
                        Style="{StaticResource IconButtonStyle}"
                        ToolTipService.ToolTip="Settings">
                    <FontIcon Glyph="&#xE713;" FontSize="18" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- Navigation Header -->
        <Grid Grid.Row="2" Padding="16,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Double-arrow: skip back one year -->
            <Button Command="{Binding PreviousYearCommand}"
                    Style="{StaticResource IconButtonStyle}"
                    Padding="6,4"
                    ToolTipService.ToolTip="Previous year">
                <FontIcon Glyph="&#xE72B;" FontSize="16" />
            </Button>

            <!-- Single-arrow: step back one period -->
            <Button Grid.Column="1"
                    Command="{Binding PreviousCommand}"
                    Style="{StaticResource IconButtonStyle}"
                    Padding="4,4"
                    ToolTipService.ToolTip="Previous">
                <FontIcon Glyph="&#xE76B;" FontSize="20" />
            </Button>

            <!-- Clickable title with Year Jump flyout — styled as a pill button -->
            <Button x:Name="NavigationTitleButton"
                    Grid.Column="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="14,6"
                    CornerRadius="16"
                    Background="{ThemeResource SurfaceBrush}"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    ToolTipService.ToolTip="Click to jump to a specific year">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="{Binding DisplayMonthYear}"
                               Style="{StaticResource TitleTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                               VerticalAlignment="Center" />
                    <FontIcon Glyph="&#xE70D;"
                              FontSize="11"
                              VerticalAlignment="Center"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <Button.Flyout>
                    <Flyout Placement="Bottom">
                        <Flyout.FlyoutPresenterStyle>
                            <Style TargetType="FlyoutPresenter">
                                <Setter Property="Background" Value="{ThemeResource SurfaceBrush}" />
                            </Style>
                        </Flyout.FlyoutPresenterStyle>
                        <StackPanel Spacing="8" Padding="4" MinWidth="220">
                            <TextBlock Text="Jump to Gregorian Year"
                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding YearInputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         PlaceholderText="e.g. 1726"
                                         MinWidth="140" />
                                <Button Grid.Column="1"
                                        Content="Go"
                                        Margin="8,0,0,0"
                                        Click="OnJumpToYearClicked" />
                            </Grid>
                            <TextBlock Text="Enter a year (1–9999) and press Go."
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
            </Button>

            <!-- Single-arrow: step forward one period -->
            <Button Grid.Column="3"
                    Command="{Binding NextCommand}"
                    Style="{StaticResource IconButtonStyle}"
                    Padding="4,4"
                    ToolTipService.ToolTip="Next">
                <FontIcon Glyph="&#xE76C;" FontSize="20" />
            </Button>

            <!-- Double-arrow: skip forward one year -->
            <Button Grid.Column="4"
                    Command="{Binding NextYearCommand}"
                    Style="{StaticResource IconButtonStyle}"
                    Padding="6,4"
                    ToolTipService.ToolTip="Next year">
                <FontIcon Glyph="&#xE72A;" FontSize="16" />
            </Button>
        </Grid>

        <!-- ==================== VIEW CONTENT AREA ==================== -->

        <!-- MONTH VIEW -->
        <ScrollViewer Grid.Row="3"
                      Visibility="{Binding IsMonthView, Converter={StaticResource BoolToVisibilityConverter}}"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Padding="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Day of Week Headers -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Sun" HorizontalAlignment="Center"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Grid.Column="1" Text="Mon" HorizontalAlignment="Center"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Grid.Column="2" Text="Tue" HorizontalAlignment="Center"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Grid.Column="3" Text="Wed" HorizontalAlignment="Center"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Grid.Column="4" Text="Thu" HorizontalAlignment="Center"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Grid.Column="5" Text="Fri" HorizontalAlignment="Center"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Grid.Column="6" Text="Sat" HorizontalAlignment="Center"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </Grid>

                <!-- Calendar Days Grid - built in code-behind -->
                <Grid x:Name="MonthGrid" Grid.Row="1" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                </Grid>
            </Grid>
        </ScrollViewer>

        <!-- WEEK VIEW -->
        <Grid Grid.Row="3" Padding="8"
              Visibility="{Binding IsWeekView, Converter={StaticResource BoolToVisibilityConverter}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Week Day Headers -->
                    <ItemsControl ItemsSource="{Binding WeekColumns}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:WeekDayColumnViewModel">
                                <StackPanel Width="120" HorizontalAlignment="Center" Padding="4,4">
                                    <TextBlock Text="{x:Bind DayOfWeek}"
                                               HorizontalAlignment="Center"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <Grid HorizontalAlignment="Center" Margin="0,2,0,0">
                                        <Ellipse Width="32" Height="32"
                                                 Fill="{ThemeResource PrimaryBrush}"
                                                 Visibility="{x:Bind IsToday, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        <TextBlock Text="{x:Bind DayNumber}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="16"
                                                   FontWeight="{x:Bind IsToday, Converter={StaticResource BoolToFontWeightConverter}}"
                                                   Foreground="{x:Bind IsToday, Converter={StaticResource BoolToForegroundConverter}}" />
                                    </Grid>
                                    <TextBlock Text="{x:Bind CrossReference}"
                                               HorizontalAlignment="Center"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               Visibility="{x:Bind HasCrossReference, Converter={StaticResource BoolToVisibilityConverter}}"
                                               TextTrimming="CharacterEllipsis"
                                               FontSize="9" />
                                    <TextBlock Text="{x:Bind DayStartDisplay}"
                                               HorizontalAlignment="Center"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               Visibility="{x:Bind HasDayStartDisplay, Converter={StaticResource BoolToVisibilityConverter}}"
                                               TextTrimming="CharacterEllipsis"
                                               FontSize="9" />
                                    <TextBlock Text="{x:Bind LunarConjunctionDisplay}"
                                               HorizontalAlignment="Center"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource PrimaryBrush}"
                                               Visibility="{x:Bind HasLunarConjunctionDisplay, Converter={StaticResource BoolToVisibilityConverter}}"
                                               FontSize="9"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Bind CrescentIlluminationDisplay}"
                                               HorizontalAlignment="Center"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource PrimaryBrush}"
                                               Visibility="{x:Bind HasCrescentIlluminationDisplay, Converter={StaticResource BoolToVisibilityConverter}}"
                                               FontSize="9" />
                                    <TextBlock Text="{x:Bind AstronomicalEventDisplay}"
                                               HorizontalAlignment="Center"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="#FF00A078"
                                               Visibility="{x:Bind HasAstronomicalEventDisplay, Converter={StaticResource BoolToVisibilityConverter}}"
                                               FontSize="9"
                                               FontWeight="SemiBold" />
                                    <ItemsControl ItemsSource="{x:Bind HolidayDisplays}"
                                                    Visibility="{x:Bind HasHolidayDisplay, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="x:String">
                                                <Border Background="#28C88200"
                                                        BorderBrush="#FFC88200"
                                                        BorderThickness="1"
                                                        CornerRadius="3"
                                                        Padding="4,2"
                                                        Margin="0,1,0,0"
                                                        HorizontalAlignment="Center">
                                                    <TextBlock Text="{x:Bind}"
                                                               HorizontalAlignment="Center"
                                                               Foreground="#FFC88200"
                                                               FontSize="9"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxLines="1" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Week Hour Grid -->
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding WeekColumns}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:WeekDayColumnViewModel">
                                <Border Width="120"
                                        BorderBrush="{ThemeResource DividerBrush}"
                                        BorderThickness="0,0,1,0">
                                    <ItemsControl ItemsSource="{x:Bind HourSlots}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="local:HourSlotViewModel">
                                                <Border Height="48"
                                                        BorderBrush="{ThemeResource DividerBrush}"
                                                        BorderThickness="0,0,0,1"
                                                        Padding="2">
                                                    <ItemsControl ItemsSource="{x:Bind Events}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="local:CalendarEventViewModel">
                                                                <Border Background="{x:Bind DisplayColorHex, Converter={StaticResource HexToBrushConverter}}"
                                                                        CornerRadius="4"
                                                                        Padding="4,2"
                                                                        Margin="0,1"
                                                                        Tapped="OnEventTapped">
                                                                    <TextBlock Text="{x:Bind Title}"
                                                                               Foreground="{x:Bind TextColorHex, Converter={StaticResource HexToBrushConverter}}"
                                                                               FontSize="10"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               MaxLines="1" />
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- DAY VIEW -->
        <Grid Grid.Row="3" Padding="8"
              Visibility="{Binding IsDayView, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Day Header -->
            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,8" Spacing="2">
                <TextBlock Text="{Binding DayViewDateDisplay}"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{Binding DayViewBiblicalDayStartDisplay}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Visibility="{Binding DayViewBiblicalDayStartDisplay, Converter={StaticResource NullToVisibilityConverter}}" />
                <TextBlock Text="{Binding DayViewLunarConjunctionDisplay}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource PrimaryBrush}"
                           HorizontalAlignment="Center"
                           FontWeight="SemiBold"
                           Visibility="{Binding DayViewLunarConjunctionDisplay, Converter={StaticResource NullToVisibilityConverter}}" />
                <TextBlock Text="{Binding DayViewCrescentIlluminationDisplay}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource PrimaryBrush}"
                           HorizontalAlignment="Center"
                           Visibility="{Binding DayViewCrescentIlluminationDisplay, Converter={StaticResource NullToVisibilityConverter}}" />
                <TextBlock Text="{Binding DayViewAstronomicalEventDisplay}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="#FF00A078"
                           HorizontalAlignment="Center"
                           FontWeight="SemiBold"
                           Visibility="{Binding DayViewAstronomicalEventDisplay, Converter={StaticResource NullToVisibilityConverter}}" />
                <ItemsControl ItemsSource="{Binding DayViewHolidayDisplays}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Border Background="#28C88200"
                                    BorderBrush="#FFC88200"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8,4"
                                    Margin="0,2,0,0"
                                    HorizontalAlignment="Center">
                                <TextBlock Text="{x:Bind}"
                                           Foreground="#FFC88200"
                                           HorizontalAlignment="Center"
                                           FontWeight="SemiBold" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Hour Slots -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding DayHours}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="local:HourSlotViewModel">
                            <Grid MinHeight="60">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Hour Label -->
                                <TextBlock Text="{x:Bind HourDisplay}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Top"
                                           HorizontalAlignment="Right"
                                           Padding="0,0,8,0" />

                                <!-- Event Area -->
                                <Border Grid.Column="1"
                                        BorderBrush="{ThemeResource DividerBrush}"
                                        BorderThickness="0,1,0,0"
                                        Padding="4,2">
                                    <ItemsControl ItemsSource="{x:Bind Events}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="local:CalendarEventViewModel">
                                                <Border Background="{x:Bind DisplayColorHex, Converter={StaticResource HexToBrushConverter}}"
                                                        CornerRadius="4"
                                                        Padding="8,4"
                                                        Margin="0,2"
                                                        Tapped="OnEventTapped">
                                                    <StackPanel>
                                                        <TextBlock Text="{x:Bind Title}"
                                                                   Foreground="{x:Bind TextColorHex, Converter={StaticResource HexToBrushConverter}}"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{x:Bind TimeRangeDisplay}"
                                                                   Foreground="{x:Bind TextColorHex, Converter={StaticResource HexToBrushConverter}}"
                                                                   FontSize="11"
                                                                   Opacity="0.9" />
                                                        <TextBlock Text="{x:Bind Location}"
                                                                   Foreground="{x:Bind TextColorHex, Converter={StaticResource HexToBrushConverter}}"
                                                                   FontSize="11"
                                                                   Opacity="0.7"
                                                                   Visibility="{x:Bind Location, Converter={StaticResource NullToVisibilityConverter}}" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- YEAR VIEW - built in code-behind -->
        <ScrollViewer Grid.Row="3" Padding="8"
                      Visibility="{Binding IsYearView, Converter={StaticResource BoolToVisibilityConverter}}"
                      VerticalScrollBarVisibility="Auto">
            <Grid x:Name="YearGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
            </Grid>
        </ScrollViewer>

        <!-- AGENDA VIEW -->
        <Grid Grid.Row="3" Padding="8"
              Visibility="{Binding IsAgendaView, Converter={StaticResource BoolToVisibilityConverter}}">
            <ListView ItemsSource="{Binding AgendaGroups}"
                      SelectionMode="None"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,0,0,4" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:AgendaGroupViewModel">
                        <StackPanel>
                            <!-- Date Header -->
                            <Border Background="{ThemeResource SurfaceVariantBrush}"
                                    Padding="12,8"
                                    CornerRadius="4,4,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{x:Bind DateDisplay}"
                                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                                   FontWeight="{x:Bind IsToday, Converter={StaticResource BoolToFontWeightConverter}}" />
                                        <TextBlock Text="{x:Bind CrossReference}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   Visibility="{x:Bind HasCrossReference, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        <TextBlock Text="{x:Bind DayStartDisplay}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   Visibility="{x:Bind HasDayStartDisplay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        <TextBlock Text="{x:Bind LunarConjunctionDisplay}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource PrimaryBrush}"
                                                   FontWeight="SemiBold"
                                                   Visibility="{x:Bind HasLunarConjunctionDisplay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        <TextBlock Text="{x:Bind CrescentIlluminationDisplay}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource PrimaryBrush}"
                                                   Visibility="{x:Bind HasCrescentIlluminationDisplay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        <TextBlock Text="{x:Bind AstronomicalEventDisplay}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="#FF00A078"
                                                   FontWeight="SemiBold"
                                                   Visibility="{x:Bind HasAstronomicalEventDisplay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        <ItemsControl ItemsSource="{x:Bind HolidayDisplays}"
                                                        Visibility="{x:Bind HasHolidayDisplay, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="x:String">
                                                    <Border Background="#28C88200"
                                                            BorderBrush="#FFC88200"
                                                            BorderThickness="1"
                                                            CornerRadius="3"
                                                            Padding="6,3"
                                                            Margin="0,1,0,0">
                                                        <TextBlock Text="{x:Bind}"
                                                                   Foreground="#FFC88200"
                                                                   FontWeight="SemiBold"
                                                                   Style="{StaticResource CaptionTextBlockStyle}" />
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                    <Border Grid.Column="1"
                                            Background="{ThemeResource PrimaryBrush}"
                                            CornerRadius="12"
                                            Padding="8,2"
                                            Visibility="{x:Bind IsToday, Converter={StaticResource BoolToVisibilityConverter}}"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="Today"
                                                   Foreground="White"
                                                   FontSize="11" />
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Events List -->
                            <ItemsControl ItemsSource="{x:Bind Events}"
                                          Margin="0,0,0,4">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="local:CalendarEventViewModel">
                                        <Border Background="{ThemeResource SurfaceBrush}"
                                                Padding="12,10"
                                                BorderBrush="{ThemeResource DividerBrush}"
                                                BorderThickness="0,0,0,1"
                                                Tapped="OnEventTapped">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="4" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <!-- Color Bar -->
                                                <Border Background="{x:Bind DisplayColorHex, Converter={StaticResource HexToBrushConverter}}"
                                                        CornerRadius="2"
                                                        Width="4" />

                                                <!-- Event Details -->
                                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                                    <TextBlock Text="{x:Bind Title}"
                                                               Style="{StaticResource BodyTextBlockStyle}"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Text="{x:Bind TimeRangeDisplay}"
                                                               Style="{StaticResource CaptionTextBlockStyle}"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                    <TextBlock Text="{x:Bind Location}"
                                                               Style="{StaticResource CaptionTextBlockStyle}"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                               Visibility="{x:Bind Location, Converter={StaticResource NullToVisibilityConverter}}" />
                                                </StackPanel>

                                                <!-- Duration -->
                                                <TextBlock Grid.Column="2"
                                                           Text="{x:Bind DurationDisplay}"
                                                           Style="{StaticResource CaptionTextBlockStyle}"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- No Events Placeholder -->
                            <TextBlock Text="{x:Bind NoEventsText}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Margin="16,8"
                                       Visibility="{x:Bind HasEvents, Converter={StaticResource InverseBoolConverter}}" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- Floating Action Button - New Event -->
        <Button Grid.Row="3"
                Command="{Binding NewEventCommand}"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,24,24"
                Width="56" Height="56"
                CornerRadius="28"
                Background="{ThemeResource PrimaryBrush}"
                Padding="0">
            <FontIcon Glyph="&#xE710;"
                      FontSize="24"
                      Foreground="White" />
        </Button>

        <!-- Loading Indicator -->
        <ProgressRing Grid.RowSpan="4"
                      IsActive="{Binding IsBusy}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Width="48"
                      Height="48" />
    </Grid>
</Page>
