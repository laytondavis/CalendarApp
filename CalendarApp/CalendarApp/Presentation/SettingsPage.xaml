<Page x:Class="CalendarApp.Presentation.SettingsPage"
      x:Name="SettingsRoot"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:CalendarApp.Presentation"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource BackgroundBrush}">

    <Grid utu:SafeArea.Insets="VisibleBounds">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Padding="16,12" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Command="{Binding GoBackCommand}"
                    VerticalAlignment="Center"
                    Padding="12,6"
                    Background="{ThemeResource PrimaryBrush}"
                    Foreground="White"
                    CornerRadius="4"
                    Content="Back" />

            <TextBlock Grid.Column="1"
                       Text="Settings"
                       Style="{StaticResource TitleTextBlockStyle}"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0" />
        </Grid>

        <!-- Settings Content — four tabs, each with its own scroll area -->
        <TabView x:Name="SettingsTabView"
                 Grid.Row="1"
                 IsAddTabButtonVisible="False"
                 TabWidthMode="Equal"
                 Loaded="OnTabViewLoaded">

            <!-- ══════════════════════════════════════════════════
                 TAB 1 — VISUAL DISPLAY &amp; CALCULATIONS
                 ══════════════════════════════════════════════════ -->
            <TabViewItem Header="Display &amp; Calc" IsClosable="False">
                <ScrollViewer Padding="16">
                    <StackPanel Spacing="16" MaxWidth="600" HorizontalAlignment="Left">

                        <!-- Theme -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Theme" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="Choose the app's color scheme"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ComboBox SelectedIndex="{Binding SelectedThemeIndex, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch"
                                      MinWidth="250"
                                      Margin="0,4,0,0">
                                <ComboBoxItem Content="System Default" />
                                <ComboBoxItem Content="Dark" />
                                <ComboBoxItem Content="Light" />
                                <ComboBoxItem Content="Windows 11" />
                                <ComboBoxItem Content="Windows XP Classic" />
                                <ComboBoxItem Content="Modern macOS" />
                                <ComboBoxItem Content="Classic macOS X" />
                            </ComboBox>
                        </StackPanel>

                        <!-- Default Calendar Mode -->
                        <StackPanel Spacing="4">
                            <CheckBox IsChecked="{Binding UseLastSelectedCalendarType, Mode=TwoWay}"
                                      Content="Use last selected calendar type"
                                      Margin="0,0,0,4" />
                            <TextBlock Text="When checked, switching calendar modes on the main screen will update the default. When unchecked, the default is set only here."
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Default Calendar Mode" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="Calendar system used when the app starts"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ComboBox SelectedIndex="{Binding SelectedCalendarModeIndex, Mode=TwoWay}"
                                      IsEnabled="{Binding IsCalendarModeEditable}"
                                      HorizontalAlignment="Stretch"
                                      MinWidth="250"
                                      Margin="0,4,0,0">
                                <ComboBoxItem Content="Gregorian" />
                                <ComboBoxItem Content="Julian" />
                                <ComboBoxItem Content="Biblical" />
                            </ComboBox>
                        </StackPanel>

                        <!-- Biblical Holidays -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Biblical Holidays" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <CheckBox IsChecked="{Binding ShowBiblicalHolidays, Mode=TwoWay}"
                                      Content="Show Biblical holy days on Gregorian and Julian calendars"
                                      Margin="0,4,0,0" />
                            <TextBlock Text="When enabled, Biblical holy days (Passover, Pentecost, Trumpets, etc.) appear on all calendar views with an amber border. On midnight-based calendars a note shows the sunset time when each day begins."
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <!-- Cross-calendar overlays -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Also Show" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="Overlay events from other calendar systems on the current view."
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />
                            <CheckBox IsChecked="{Binding ShowGregorianEvents, Mode=TwoWay}"
                                      Content="Gregorian calendar events"
                                      Margin="0,4,0,0" />
                            <CheckBox IsChecked="{Binding ShowJulianEvents, Mode=TwoWay}"
                                      Content="Julian calendar events"
                                      Margin="0,2,0,0" />
                            <CheckBox IsChecked="{Binding ShowBiblicalEvents, Mode=TwoWay}"
                                      Content="Biblical calendar events"
                                      Margin="0,2,0,0" />
                        </StackPanel>

                        <!-- Astronomy calculation method -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Astronomy Calculation Method" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="How sunset, lunar phases, and equinox dates are calculated"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ComboBox SelectedIndex="{Binding SelectedAstronomyModeIndex, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch"
                                      MinWidth="250"
                                      Margin="0,4,0,0">
                                <ComboBoxItem Content="Built-in (NOAA Algorithms)" />
                                <ComboBoxItem Content="Web API (sunrise-sunset.org)" />
                            </ComboBox>
                            <TextBlock Text="Built-in uses NOAA solar algorithms. Web API queries sunrise-sunset.org (requires internet)."
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0" />
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

            <!-- ══════════════════════════════════════════════════
                 TAB 2 — LOCATIONS
                 ══════════════════════════════════════════════════ -->
            <TabViewItem Header="Locations" IsClosable="False">
                <ScrollViewer Padding="16">
                    <StackPanel Spacing="16" MaxWidth="600" HorizontalAlignment="Left">

                        <!-- Location Mode -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Location Mode" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="How the app determines your location for sunset calculations"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ComboBox SelectedIndex="{Binding SelectedLocationModeIndex, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch"
                                      MinWidth="250"
                                      Margin="0,4,0,0">
                                <ComboBoxItem Content="GPS with Manual Fallback" />
                                <ComboBoxItem Content="Manual Only" />
                            </ComboBox>
                        </StackPanel>

                        <!-- GPS Status -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="GPS Location" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <Border Background="{ThemeResource SurfaceBrush}"
                                    CornerRadius="6"
                                    Padding="12,10">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="{Binding GpsLocationDisplay}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               TextWrapping="Wrap" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Content="Refresh GPS"
                                                Command="{Binding RefreshGpsCommand}"
                                                IsEnabled="{Binding IsGpsBusy, Converter={StaticResource InverseBoolConverter}}" />
                                        <ProgressRing IsActive="{Binding IsGpsBusy}"
                                                      Width="20" Height="20"
                                                      VerticalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Saved Locations List -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Saved Locations" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="Tap a location to make it active for Biblical calendar calculations. Jerusalem is always available and cannot be removed."
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />

                            <ListView x:Name="SavedLocationsList"
                                      ItemsSource="{Binding SavedLocations}"
                                      IsItemClickEnabled="True"
                                      SelectionMode="None"
                                      ItemClick="OnSavedLocationClicked"
                                      Margin="0,4,0,0">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0,2" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{ThemeResource SurfaceBrush}" CornerRadius="6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="4" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Border Background="{Binding IsActive, Converter={StaticResource BoolToActiveBackgroundConverter}}"
                                                        CornerRadius="6,0,0,6" />
                                                <StackPanel Grid.Column="1" Padding="10,8" Spacing="2">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                                                    <TextBlock Text="{Binding Coords}"
                                                               Style="{StaticResource CaptionTextBlockStyle}"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                </StackPanel>
                                                <Button Grid.Column="2"
                                                        Content="✕"
                                                        Padding="12,8"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,4,0"
                                                        Tag="{Binding}"
                                                        Click="OnRemoveLocationClicked"
                                                        Visibility="{Binding IsRemovable, Converter={StaticResource BoolToVisibilityConverter}}"
                                                        Style="{StaticResource TextButtonStyle}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <!-- Add location (shown when fewer than 8 user locations) -->
                            <StackPanel Spacing="8"
                                        Margin="0,12,0,0"
                                        Visibility="{Binding CanAddLocation, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="Add a location:" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding LocationSearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             PlaceholderText="Search for a city or place..."
                                             MinWidth="250" />
                                    <Button Grid.Column="1"
                                            Command="{Binding SearchLocationCommand}"
                                            Content="Search"
                                            Margin="8,0,0,0" />
                                </Grid>
                                <ProgressRing IsActive="{Binding IsSearchingLocations}"
                                              Width="24" Height="24"
                                              HorizontalAlignment="Left" />
                                <TextBlock Text="Multiple matches found — select one:"
                                           Style="{StaticResource BodyStrongTextBlockStyle}"
                                           Margin="0,4,0,2"
                                           Visibility="{Binding ShowLocationPicker, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <ListView x:Name="LocationResultsList"
                                          ItemsSource="{Binding LocationSuggestions}"
                                          IsItemClickEnabled="True"
                                          SelectionMode="None"
                                          ItemClick="OnLocationResultClicked"
                                          Visibility="{Binding ShowLocationPicker, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Padding="4,8" Spacing="2">
                                                <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}">
                                                    <Run Text="{Binding City}" /><Run Text=", " /><Run Text="{Binding State}" />
                                                </TextBlock>
                                                <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                    <Run Text="ZIP: " /><Run Text="{Binding ZipCode}" />
                                                    <Run Text="   " /><Run Text="{Binding County}" />
                                                </TextBlock>
                                                <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                    <Run Text="Lat: " /><Run Text="{Binding Latitude}" />
                                                    <Run Text="   Lon: " /><Run Text="{Binding Longitude}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>

                            <!-- Shown when all 8 user slots are used -->
                            <TextBlock Text="Maximum of 8 locations reached. Remove a location to add another."
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Margin="0,8,0,0"
                                       Visibility="{Binding IsLocationListFull, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </StackPanel>

                        <!-- Status feedback for location add/remove operations -->
                        <TextBlock Text="{Binding StatusMessage}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource PrimaryBrush}"
                                   Visibility="{Binding StatusMessage, Converter={StaticResource NullToVisibilityConverter}}"
                                   Margin="0,0,0,8" />

                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

            <!-- ══════════════════════════════════════════════════
                 TAB 3 — LINKED CALENDARS
                 ══════════════════════════════════════════════════ -->
            <TabViewItem Header="Linked Calendars" IsClosable="False">
                <ScrollViewer Padding="16">
                    <StackPanel Spacing="16" MaxWidth="600" HorizontalAlignment="Left">

                        <!-- Google — signed-out state -->
                        <StackPanel Spacing="8"
                                    Visibility="{Binding IsGoogleSignedIn, Converter={StaticResource InverseBoolConverter}}">
                            <TextBlock Text="Google Calendar" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="Sign in to sync your events with Google Calendar."
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="Signing in opens your browser so Google can verify your credentials securely. No password is entered in this app."
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                <Button Content="Sign in to Google Calendar"
                                        Command="{Binding GoogleSignInCommand}"
                                        Style="{StaticResource FilledTonalButtonStyle}"
                                        IsEnabled="{Binding IsGoogleBusy, Converter={StaticResource InverseBoolConverter}}" />
                                <ProgressRing IsActive="{Binding IsGoogleBusy}"
                                              Width="20" Height="20"
                                              VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="{Binding GoogleStatusText}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding HasGoogleError, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </StackPanel>

                        <!-- Google — signed-in state -->
                        <Border Background="{ThemeResource SurfaceBrush}"
                                CornerRadius="8"
                                Padding="16"
                                Visibility="{Binding IsGoogleSignedIn, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Spacing="8">

                                <!-- Account row -->
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE77B;" FontSize="20" VerticalAlignment="Center" />
                                    <StackPanel>
                                        <TextBlock Text="Google Calendar — Signed in"
                                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        <TextBlock Text="{Binding GoogleAccountEmail}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </StackPanel>

                                <!-- Sign-out -->
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="Sign Out"
                                            Command="{Binding GoogleSignOutCommand}"
                                            Style="{StaticResource TextButtonStyle}"
                                            IsEnabled="{Binding IsGoogleBusy, Converter={StaticResource InverseBoolConverter}}" />
                                    <ProgressRing IsActive="{Binding IsGoogleBusy}"
                                                  Width="20" Height="20"
                                                  VerticalAlignment="Center" />
                                </StackPanel>

                                <!-- Re-pull -->
                                <Button Content="Re-pull from Google Calendar"
                                        Command="{Binding SyncNowCommand}"
                                        IsEnabled="{Binding IsGoogleBusy, Converter={StaticResource InverseBoolConverter}}"
                                        HorizontalAlignment="Stretch" />

                                <!-- Sync status -->
                                <TextBlock Text="{Binding GoogleStatusText}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding GoogleStatusText, Converter={StaticResource NullToVisibilityConverter}}" />

                                <!-- Calendar selection list -->
                                <StackPanel Spacing="4"
                                            Margin="0,8,0,0"
                                            Visibility="{Binding HasGoogleCalendars, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="Calendars to sync" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Text="Check the calendars whose events you want to see. Changes take effect on the next sync."
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                    <ListView ItemsSource="{Binding GoogleCalendars}"
                                              SelectionMode="None"
                                              Margin="0,4,0,0"
                                              IsItemClickEnabled="False">
                                        <ListView.ItemContainerStyle>
                                            <Style TargetType="ListViewItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                <Setter Property="Padding" Value="0" />
                                                <Setter Property="Margin" Value="0,1" />
                                            </Style>
                                        </ListView.ItemContainerStyle>
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid VerticalAlignment="Center">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Button Width="24" Height="24"
                                                            CornerRadius="12"
                                                            Padding="0"
                                                            Margin="0,0,8,0"
                                                            VerticalAlignment="Center"
                                                            Background="{Binding UserColorBrush}"
                                                            ToolTipService.ToolTip="Pick a color for this calendar">
                                                        <Button.Flyout>
                                                            <Flyout Placement="Bottom">
                                                                <ColorPicker SelectedColor="{Binding UserColor, Mode=TwoWay}"
                                                                             IsAlphaEnabled="False"
                                                                             IsHexInputVisible="True"
                                                                             ColorSpectrumShape="Ring" />
                                                            </Flyout>
                                                        </Button.Flyout>
                                                    </Button>
                                                    <CheckBox Grid.Column="1"
                                                              IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                              Padding="4,0">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <TextBlock Text="{Binding Summary}"
                                                                       Style="{StaticResource BodyTextBlockStyle}"
                                                                       VerticalAlignment="Center" />
                                                            <TextBlock Text="(primary)"
                                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                       VerticalAlignment="Center"
                                                                       Visibility="{Binding IsPrimary, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                        </StackPanel>
                                                    </CheckBox>
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </StackPanel>

                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

            <!-- ══════════════════════════════════════════════════
                 TAB 4 — ABOUT
                 ══════════════════════════════════════════════════ -->
            <TabViewItem Header="About" IsClosable="False">
                <ScrollViewer Padding="16">
                    <StackPanel Spacing="16" MaxWidth="600" HorizontalAlignment="Left">

                        <!-- App info card -->
                        <Border Background="{ThemeResource SurfaceBrush}"
                                CornerRadius="8"
                                Padding="16">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Calendar App"
                                           Style="{StaticResource BodyStrongTextBlockStyle}"
                                           FontSize="16" />
                                <TextBlock Text="{Binding AppVersion}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Text="A cross-platform calendar supporting Gregorian, Julian, and Biblical calendar systems with Google Calendar sync."
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>

                        <!-- Update section — desktop (Velopack) only -->
                        <Border Background="{ThemeResource SurfaceBrush}"
                                CornerRadius="8"
                                Padding="16"
                                Visibility="{Binding IsUpdateSupported, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Software Updates"
                                           Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="The app checks for updates automatically on launch. You can also check manually below."
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" />

                                <!-- Status text -->
                                <TextBlock Text="{Binding UpdateStatusText}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource PrimaryBrush}"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding UpdateStatusText, Converter={StaticResource NullToVisibilityConverter}}" />

                                <!-- Download progress bar -->
                                <ProgressBar Value="{Binding UpdateDownloadProgress}"
                                             Minimum="0" Maximum="100"
                                             HorizontalAlignment="Stretch"
                                             Visibility="{Binding IsDownloadingUpdate, Converter={StaticResource BoolToVisibilityConverter}}" />

                                <!-- Action buttons -->
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <!-- Check button — visible when no update found yet -->
                                    <Button Content="Check for Updates"
                                            Command="{Binding CheckForUpdatesCommand}"
                                            IsEnabled="{Binding IsCheckingForUpdates, Converter={StaticResource InverseBoolConverter}}"
                                            Visibility="{Binding IsUpdateAvailable, Converter={StaticResource InverseBoolConverter}}" />
                                    <!-- Desktop: update downloaded — install immediately -->
                                    <Button Content="Restart &amp; Install Update"
                                            Command="{Binding InstallUpdateCommand}"
                                            Style="{StaticResource FilledTonalButtonStyle}"
                                            Visibility="{Binding IsUpdateReady, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <!-- Android / non-desktop: open GitHub releases page -->
                                    <Button Content="Download Update"
                                            Command="{Binding OpenReleasesPageCommand}"
                                            Style="{StaticResource FilledTonalButtonStyle}"
                                            Visibility="{Binding IsDownloadLinkAvailable, Converter={StaticResource BoolToVisibilityConverter}}"
                                            Padding="12,8" />
                                    <ProgressRing IsActive="{Binding IsCheckingForUpdates}"
                                                  Width="20" Height="20"
                                                  VerticalAlignment="Center" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Exit App — Android only (makes it easy to close before installing an update) -->
                        <Border Background="{ThemeResource SurfaceBrush}"
                                CornerRadius="8"
                                Padding="16"
                                Visibility="{Binding IsAndroid, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Exit Application"
                                           Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="Fully closes the app. Useful before installing an update, since the installer cannot replace a running app."
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" />
                                <Button Content="Exit App"
                                        Command="{Binding ExitAppCommand}"
                                        HorizontalAlignment="Stretch" />
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

        </TabView>
    </Grid>
</Page>
