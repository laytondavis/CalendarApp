<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
  <uses-permission android:name="android.permission.INTERNET" />
  <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
  <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
  <application android:allowBackup="true" android:supportsRtl="true"
               android:usesCleartextTraffic="true">
    <!--
      OAuthWebViewActivity hosts Google's sign-in page in an in-app WebView so
      that the http://127.0.0.1 redirect is intercepted before Chrome's Private
      Network Access policy can block it. Not exported — only started by the app.
    -->
    <activity
      android:name="com.companyname.calendarapp.OAuthWebViewActivity"
      android:exported="false" />
  </application>
</manifest>
