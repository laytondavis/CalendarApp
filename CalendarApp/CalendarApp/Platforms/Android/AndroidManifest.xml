<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
  <uses-permission android:name="android.permission.INTERNET" />
  <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
  <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
  <application android:allowBackup="true" android:supportsRtl="true"
               android:usesCleartextTraffic="true">

    <!--
      PATH A — Web application OAuth client (credentials_android.json present):
      OAuthRedirectActivity receives the HTTPS App Link redirect from Chrome.
      android:autoVerify="true" causes Android to verify assetlinks.json at
      https://LaytonsComputers.com/.well-known/assetlinks.json so the redirect
      routes here without a browser-chooser dialog.
    -->
    <activity
      android:name="com.companyname.calendarapp.OAuthRedirectActivity"
      android:exported="true"
      android:noHistory="true">
      <intent-filter android:autoVerify="true">
        <action android:name="android.intent.action.VIEW" />
        <category android:name="android.intent.category.DEFAULT" />
        <category android:name="android.intent.category.BROWSABLE" />
        <data android:scheme="https"
              android:host="LaytonsComputers.com" />
      </intent-filter>
    </activity>

    <!--
      PATH B — Desktop OAuth client fallback (no credentials_android.json):
      OAuthWebViewActivity shows Google's sign-in page in an in-app WebView
      so the http://127.0.0.1 redirect is intercepted before Chrome's Private
      Network Access policy can block it.
    -->
    <activity
      android:name="com.companyname.calendarapp.OAuthWebViewActivity"
      android:exported="false" />

  </application>
</manifest>
