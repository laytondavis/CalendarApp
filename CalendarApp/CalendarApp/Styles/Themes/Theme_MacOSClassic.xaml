<ResourceDictionary xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
  <!-- Classic macOS X / Aqua palette (10.0 – 10.4)
       Candy-like gel buttons, brushed-metal chrome, pinstripe backgrounds.
       Includes 3D bevel brushes for that raised Aqua button effect. -->
  <ResourceDictionary.ThemeDictionaries>

    <ResourceDictionary x:Key="Light">
      <Color x:Key="PrimaryColor">#0B4F8A</Color>
      <Color x:Key="OnPrimaryColor">#FFFFFF</Color>
      <Color x:Key="PrimaryContainerColor">#A8D0F0</Color>
      <Color x:Key="OnPrimaryContainerColor">#002B52</Color>
      <Color x:Key="SecondaryColor">#3A7B8C</Color>
      <Color x:Key="OnSecondaryColor">#FFFFFF</Color>
      <Color x:Key="SecondaryContainerColor">#B0DEE8</Color>
      <Color x:Key="OnSecondaryContainerColor">#003540</Color>
      <Color x:Key="TertiaryColor">#4A7A34</Color>
      <Color x:Key="OnTertiaryColor">#FFFFFF</Color>
      <Color x:Key="TertiaryContainerColor">#C8E4B0</Color>
      <Color x:Key="OnTertiaryContainerColor">#1A2E00</Color>
      <Color x:Key="ErrorColor">#CC2222</Color>
      <Color x:Key="ErrorContainerColor">#FFD4D4</Color>
      <Color x:Key="OnErrorColor">#FFFFFF</Color>
      <Color x:Key="OnErrorContainerColor">#5A0000</Color>
      <Color x:Key="BackgroundColor">#D4D4D8</Color>
      <Color x:Key="OnBackgroundColor">#1A1A1A</Color>
      <Color x:Key="SurfaceColor">#E8E8EC</Color>
      <Color x:Key="OnSurfaceColor">#1A1A1A</Color>
      <Color x:Key="SurfaceVariantColor">#CACAD0</Color>
      <Color x:Key="OnSurfaceVariantColor">#404048</Color>
      <Color x:Key="OutlineColor">#8E8E96</Color>
      <Color x:Key="OnSurfaceInverseColor">#D4D4D8</Color>
      <Color x:Key="SurfaceInverseColor">#2A2A30</Color>
      <Color x:Key="PrimaryInverseColor">#7EB8F7</Color>
      <Color x:Key="SurfaceTintColor">#0B4F8A</Color>
      <Color x:Key="OutlineVariantColor">#B0B0B8</Color>

      <!-- Aqua 3D bevel brushes -->
      <SolidColorBrush x:Key="Bevel3DHighlightBrush" Color="#E8E8F0" />
      <SolidColorBrush x:Key="Bevel3DShadowBrush" Color="#888890" />
    </ResourceDictionary>

    <ResourceDictionary x:Key="Dark">
      <Color x:Key="PrimaryColor">#0B4F8A</Color>
      <Color x:Key="OnPrimaryColor">#FFFFFF</Color>
      <Color x:Key="PrimaryContainerColor">#A8D0F0</Color>
      <Color x:Key="OnPrimaryContainerColor">#002B52</Color>
      <Color x:Key="SecondaryColor">#3A7B8C</Color>
      <Color x:Key="OnSecondaryColor">#FFFFFF</Color>
      <Color x:Key="SecondaryContainerColor">#B0DEE8</Color>
      <Color x:Key="OnSecondaryContainerColor">#003540</Color>
      <Color x:Key="TertiaryColor">#4A7A34</Color>
      <Color x:Key="OnTertiaryColor">#FFFFFF</Color>
      <Color x:Key="TertiaryContainerColor">#C8E4B0</Color>
      <Color x:Key="OnTertiaryContainerColor">#1A2E00</Color>
      <Color x:Key="ErrorColor">#CC2222</Color>
      <Color x:Key="ErrorContainerColor">#FFD4D4</Color>
      <Color x:Key="OnErrorColor">#FFFFFF</Color>
      <Color x:Key="OnErrorContainerColor">#5A0000</Color>
      <Color x:Key="BackgroundColor">#D4D4D8</Color>
      <Color x:Key="OnBackgroundColor">#1A1A1A</Color>
      <Color x:Key="SurfaceColor">#E8E8EC</Color>
      <Color x:Key="OnSurfaceColor">#1A1A1A</Color>
      <Color x:Key="SurfaceVariantColor">#CACAD0</Color>
      <Color x:Key="OnSurfaceVariantColor">#404048</Color>
      <Color x:Key="OutlineColor">#8E8E96</Color>
      <Color x:Key="OnSurfaceInverseColor">#D4D4D8</Color>
      <Color x:Key="SurfaceInverseColor">#2A2A30</Color>
      <Color x:Key="PrimaryInverseColor">#7EB8F7</Color>
      <Color x:Key="SurfaceTintColor">#0B4F8A</Color>
      <Color x:Key="OutlineVariantColor">#B0B0B8</Color>

      <SolidColorBrush x:Key="Bevel3DHighlightBrush" Color="#E8E8F0" />
      <SolidColorBrush x:Key="Bevel3DShadowBrush" Color="#888890" />
    </ResourceDictionary>

  </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
