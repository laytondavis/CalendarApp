<ResourceDictionary xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
  <!-- Windows XP / Luna "Blue" palette
       The iconic XP look: warm silver-tan chrome (#ECE9D8), bold Luna blue
       title bars (#003399), and that distinctive green Start button.
       Includes 3D raised-bevel brushes for that classic Windows look. -->
  <ResourceDictionary.ThemeDictionaries>

    <ResourceDictionary x:Key="Light">
      <!-- XP Luna title-bar blue -->
      <Color x:Key="PrimaryColor">#003399</Color>
      <Color x:Key="OnPrimaryColor">#FFFFFF</Color>
      <Color x:Key="PrimaryContainerColor">#B8D4FF</Color>
      <Color x:Key="OnPrimaryContainerColor">#001A4D</Color>
      <!-- XP selection highlight blue -->
      <Color x:Key="SecondaryColor">#316AC5</Color>
      <Color x:Key="OnSecondaryColor">#FFFFFF</Color>
      <Color x:Key="SecondaryContainerColor">#C8DEFF</Color>
      <Color x:Key="OnSecondaryContainerColor">#001B55</Color>
      <!-- XP Start button green -->
      <Color x:Key="TertiaryColor">#21A121</Color>
      <Color x:Key="OnTertiaryColor">#FFFFFF</Color>
      <Color x:Key="TertiaryContainerColor">#C8F7C8</Color>
      <Color x:Key="OnTertiaryContainerColor">#003A00</Color>
      <Color x:Key="ErrorColor">#CC0000</Color>
      <Color x:Key="ErrorContainerColor">#FFD4D4</Color>
      <Color x:Key="OnErrorColor">#FFFFFF</Color>
      <Color x:Key="OnErrorContainerColor">#5A0000</Color>
      <!-- Warm silver-tan XP chrome -->
      <Color x:Key="BackgroundColor">#ECE9D8</Color>
      <Color x:Key="OnBackgroundColor">#000000</Color>
      <!-- Creamy XP dialog interior -->
      <Color x:Key="SurfaceColor">#F8F4E8</Color>
      <Color x:Key="OnSurfaceColor">#000000</Color>
      <Color x:Key="SurfaceVariantColor">#E0DCCA</Color>
      <Color x:Key="OnSurfaceVariantColor">#3A3A2E</Color>
      <Color x:Key="OutlineColor">#808080</Color>
      <Color x:Key="OnSurfaceInverseColor">#ECE9D8</Color>
      <Color x:Key="SurfaceInverseColor">#2D2D26</Color>
      <Color x:Key="PrimaryInverseColor">#A9C9FB</Color>
      <Color x:Key="SurfaceTintColor">#003399</Color>
      <Color x:Key="OutlineVariantColor">#ACA899</Color>

      <!-- 3D bevel brushes for raised/inset effects -->
      <SolidColorBrush x:Key="Bevel3DHighlightBrush" Color="#FFFFFF" />
      <SolidColorBrush x:Key="Bevel3DShadowBrush" Color="#808080" />
      <SolidColorBrush x:Key="Bevel3DDarkShadowBrush" Color="#404040" />
      <SolidColorBrush x:Key="Bevel3DLightBrush" Color="#D6D3C2" />
    </ResourceDictionary>

    <ResourceDictionary x:Key="Dark">
      <Color x:Key="PrimaryColor">#003399</Color>
      <Color x:Key="OnPrimaryColor">#FFFFFF</Color>
      <Color x:Key="PrimaryContainerColor">#B8D4FF</Color>
      <Color x:Key="OnPrimaryContainerColor">#001A4D</Color>
      <Color x:Key="SecondaryColor">#316AC5</Color>
      <Color x:Key="OnSecondaryColor">#FFFFFF</Color>
      <Color x:Key="SecondaryContainerColor">#C8DEFF</Color>
      <Color x:Key="OnSecondaryContainerColor">#001B55</Color>
      <Color x:Key="TertiaryColor">#21A121</Color>
      <Color x:Key="OnTertiaryColor">#FFFFFF</Color>
      <Color x:Key="TertiaryContainerColor">#C8F7C8</Color>
      <Color x:Key="OnTertiaryContainerColor">#003A00</Color>
      <Color x:Key="ErrorColor">#CC0000</Color>
      <Color x:Key="ErrorContainerColor">#FFD4D4</Color>
      <Color x:Key="OnErrorColor">#FFFFFF</Color>
      <Color x:Key="OnErrorContainerColor">#5A0000</Color>
      <Color x:Key="BackgroundColor">#ECE9D8</Color>
      <Color x:Key="OnBackgroundColor">#000000</Color>
      <Color x:Key="SurfaceColor">#F8F4E8</Color>
      <Color x:Key="OnSurfaceColor">#000000</Color>
      <Color x:Key="SurfaceVariantColor">#E0DCCA</Color>
      <Color x:Key="OnSurfaceVariantColor">#3A3A2E</Color>
      <Color x:Key="OutlineColor">#808080</Color>
      <Color x:Key="OnSurfaceInverseColor">#ECE9D8</Color>
      <Color x:Key="SurfaceInverseColor">#2D2D26</Color>
      <Color x:Key="PrimaryInverseColor">#A9C9FB</Color>
      <Color x:Key="SurfaceTintColor">#003399</Color>
      <Color x:Key="OutlineVariantColor">#ACA899</Color>

      <SolidColorBrush x:Key="Bevel3DHighlightBrush" Color="#FFFFFF" />
      <SolidColorBrush x:Key="Bevel3DShadowBrush" Color="#808080" />
      <SolidColorBrush x:Key="Bevel3DDarkShadowBrush" Color="#404040" />
      <SolidColorBrush x:Key="Bevel3DLightBrush" Color="#D6D3C2" />
    </ResourceDictionary>

  </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
