<ResourceDictionary xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
  <!-- Modern macOS (Ventura / Sonoma) palette
       Apple's system blue (#007AFF) is the primary accent.  The background
       uses iOS/macOS grouped background (#F2F2F7) — that familiar slightly-blue
       off-white.  Secondary accent is Apple's indigo (#5E5CE6).
       Tertiary uses Apple green (#34C759) as a nod to macOS status indicators. -->
  <ResourceDictionary.ThemeDictionaries>

    <ResourceDictionary x:Key="Light">
      <Color x:Key="PrimaryColor">#007AFF</Color>
      <Color x:Key="OnPrimaryColor">#FFFFFF</Color>
      <Color x:Key="PrimaryContainerColor">#D6ECFF</Color>
      <Color x:Key="OnPrimaryContainerColor">#003466</Color>
      <Color x:Key="SecondaryColor">#5E5CE6</Color>
      <Color x:Key="OnSecondaryColor">#FFFFFF</Color>
      <Color x:Key="SecondaryContainerColor">#E5E4FF</Color>
      <Color x:Key="OnSecondaryContainerColor">#1A1874</Color>
      <Color x:Key="TertiaryColor">#34C759</Color>
      <Color x:Key="OnTertiaryColor">#FFFFFF</Color>
      <Color x:Key="TertiaryContainerColor">#DCFFE6</Color>
      <Color x:Key="OnTertiaryContainerColor">#00391A</Color>
      <!-- Apple red for errors -->
      <Color x:Key="ErrorColor">#FF3B30</Color>
      <Color x:Key="ErrorContainerColor">#FFE8E7</Color>
      <Color x:Key="OnErrorColor">#FFFFFF</Color>
      <Color x:Key="OnErrorContainerColor">#680C07</Color>
      <!-- F2F2F7 is the iOS/macOS system grouped background colour -->
      <Color x:Key="BackgroundColor">#F2F2F7</Color>
      <Color x:Key="OnBackgroundColor">#1C1C1E</Color>
      <Color x:Key="SurfaceColor">#FFFFFF</Color>
      <Color x:Key="OnSurfaceColor">#1C1C1E</Color>
      <!-- E5E5EA is the macOS secondary grouped background -->
      <Color x:Key="SurfaceVariantColor">#E5E5EA</Color>
      <Color x:Key="OnSurfaceVariantColor">#6E6E73</Color>
      <Color x:Key="OutlineColor">#C6C6C8</Color>
      <Color x:Key="OnSurfaceInverseColor">#F2F2F7</Color>
      <Color x:Key="SurfaceInverseColor">#3A3A3C</Color>
      <Color x:Key="PrimaryInverseColor">#93C5FD</Color>
      <Color x:Key="SurfaceTintColor">#007AFF</Color>
      <Color x:Key="OutlineVariantColor">#D1D1D6</Color>
    </ResourceDictionary>

    <ResourceDictionary x:Key="Dark">
      <Color x:Key="PrimaryColor">#007AFF</Color>
      <Color x:Key="OnPrimaryColor">#FFFFFF</Color>
      <Color x:Key="PrimaryContainerColor">#D6ECFF</Color>
      <Color x:Key="OnPrimaryContainerColor">#003466</Color>
      <Color x:Key="SecondaryColor">#5E5CE6</Color>
      <Color x:Key="OnSecondaryColor">#FFFFFF</Color>
      <Color x:Key="SecondaryContainerColor">#E5E4FF</Color>
      <Color x:Key="OnSecondaryContainerColor">#1A1874</Color>
      <Color x:Key="TertiaryColor">#34C759</Color>
      <Color x:Key="OnTertiaryColor">#FFFFFF</Color>
      <Color x:Key="TertiaryContainerColor">#DCFFE6</Color>
      <Color x:Key="OnTertiaryContainerColor">#00391A</Color>
      <Color x:Key="ErrorColor">#FF3B30</Color>
      <Color x:Key="ErrorContainerColor">#FFE8E7</Color>
      <Color x:Key="OnErrorColor">#FFFFFF</Color>
      <Color x:Key="OnErrorContainerColor">#680C07</Color>
      <Color x:Key="BackgroundColor">#F2F2F7</Color>
      <Color x:Key="OnBackgroundColor">#1C1C1E</Color>
      <Color x:Key="SurfaceColor">#FFFFFF</Color>
      <Color x:Key="OnSurfaceColor">#1C1C1E</Color>
      <Color x:Key="SurfaceVariantColor">#E5E5EA</Color>
      <Color x:Key="OnSurfaceVariantColor">#6E6E73</Color>
      <Color x:Key="OutlineColor">#C6C6C8</Color>
      <Color x:Key="OnSurfaceInverseColor">#F2F2F7</Color>
      <Color x:Key="SurfaceInverseColor">#3A3A3C</Color>
      <Color x:Key="PrimaryInverseColor">#93C5FD</Color>
      <Color x:Key="SurfaceTintColor">#007AFF</Color>
      <Color x:Key="OutlineVariantColor">#D1D1D6</Color>
    </ResourceDictionary>

  </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
