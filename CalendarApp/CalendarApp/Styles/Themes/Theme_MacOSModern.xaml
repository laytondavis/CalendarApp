<ResourceDictionary xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
  <!-- Modern macOS (Ventura / Sonoma) palette
       Vibrant system blue on cool blue-gray background. Flat design, no 3D. -->
  <ResourceDictionary.ThemeDictionaries>

    <ResourceDictionary x:Key="Light">
      <Color x:Key="PrimaryColor">#007AFF</Color>
      <Color x:Key="OnPrimaryColor">#FFFFFF</Color>
      <Color x:Key="PrimaryContainerColor">#D0E4FF</Color>
      <Color x:Key="OnPrimaryContainerColor">#002966</Color>
      <Color x:Key="SecondaryColor">#5856D6</Color>
      <Color x:Key="OnSecondaryColor">#FFFFFF</Color>
      <Color x:Key="SecondaryContainerColor">#E0DFFF</Color>
      <Color x:Key="OnSecondaryContainerColor">#1A1874</Color>
      <Color x:Key="TertiaryColor">#28CD41</Color>
      <Color x:Key="OnTertiaryColor">#FFFFFF</Color>
      <Color x:Key="TertiaryContainerColor">#C4FFD0</Color>
      <Color x:Key="OnTertiaryContainerColor">#003A0E</Color>
      <Color x:Key="ErrorColor">#FF3B30</Color>
      <Color x:Key="ErrorContainerColor">#FFE0DE</Color>
      <Color x:Key="OnErrorColor">#FFFFFF</Color>
      <Color x:Key="OnErrorContainerColor">#680C07</Color>
      <Color x:Key="BackgroundColor">#E8EAF0</Color>
      <Color x:Key="OnBackgroundColor">#1C1C1E</Color>
      <Color x:Key="SurfaceColor">#FFFFFF</Color>
      <Color x:Key="OnSurfaceColor">#1C1C1E</Color>
      <Color x:Key="SurfaceVariantColor">#DDE0E8</Color>
      <Color x:Key="OnSurfaceVariantColor">#48484A</Color>
      <Color x:Key="OutlineColor">#C6C6C8</Color>
      <Color x:Key="OnSurfaceInverseColor">#E8EAF0</Color>
      <Color x:Key="SurfaceInverseColor">#3A3A3C</Color>
      <Color x:Key="PrimaryInverseColor">#64B5FF</Color>
      <Color x:Key="SurfaceTintColor">#007AFF</Color>
      <Color x:Key="OutlineVariantColor">#D1D1D6</Color>

      <!-- No 3D bevel for modern macOS — flat design -->
      <SolidColorBrush x:Key="Bevel3DHighlightBrush" Color="Transparent" />
      <SolidColorBrush x:Key="Bevel3DShadowBrush" Color="Transparent" />
    </ResourceDictionary>

    <ResourceDictionary x:Key="Dark">
      <Color x:Key="PrimaryColor">#007AFF</Color>
      <Color x:Key="OnPrimaryColor">#FFFFFF</Color>
      <Color x:Key="PrimaryContainerColor">#D0E4FF</Color>
      <Color x:Key="OnPrimaryContainerColor">#002966</Color>
      <Color x:Key="SecondaryColor">#5856D6</Color>
      <Color x:Key="OnSecondaryColor">#FFFFFF</Color>
      <Color x:Key="SecondaryContainerColor">#E0DFFF</Color>
      <Color x:Key="OnSecondaryContainerColor">#1A1874</Color>
      <Color x:Key="TertiaryColor">#28CD41</Color>
      <Color x:Key="OnTertiaryColor">#FFFFFF</Color>
      <Color x:Key="TertiaryContainerColor">#C4FFD0</Color>
      <Color x:Key="OnTertiaryContainerColor">#003A0E</Color>
      <Color x:Key="ErrorColor">#FF3B30</Color>
      <Color x:Key="ErrorContainerColor">#FFE0DE</Color>
      <Color x:Key="OnErrorColor">#FFFFFF</Color>
      <Color x:Key="OnErrorContainerColor">#680C07</Color>
      <Color x:Key="BackgroundColor">#E8EAF0</Color>
      <Color x:Key="OnBackgroundColor">#1C1C1E</Color>
      <Color x:Key="SurfaceColor">#FFFFFF</Color>
      <Color x:Key="OnSurfaceColor">#1C1C1E</Color>
      <Color x:Key="SurfaceVariantColor">#DDE0E8</Color>
      <Color x:Key="OnSurfaceVariantColor">#48484A</Color>
      <Color x:Key="OutlineColor">#C6C6C8</Color>
      <Color x:Key="OnSurfaceInverseColor">#E8EAF0</Color>
      <Color x:Key="SurfaceInverseColor">#3A3A3C</Color>
      <Color x:Key="PrimaryInverseColor">#64B5FF</Color>
      <Color x:Key="SurfaceTintColor">#007AFF</Color>
      <Color x:Key="OutlineVariantColor">#D1D1D6</Color>

      <SolidColorBrush x:Key="Bevel3DHighlightBrush" Color="Transparent" />
      <SolidColorBrush x:Key="Bevel3DShadowBrush" Color="Transparent" />
    </ResourceDictionary>

  </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
