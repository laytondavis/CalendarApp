<ResourceDictionary xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
  <!-- Windows 11 / Fluent Design palette
       Mica material: warm cream-gray background with lavender-tinted surfaces.
       Subtle elevation via soft shadows (no hard 3D bevels). -->
  <ResourceDictionary.ThemeDictionaries>

    <ResourceDictionary x:Key="Light">
      <Color x:Key="PrimaryColor">#005FB8</Color>
      <Color x:Key="OnPrimaryColor">#FFFFFF</Color>
      <Color x:Key="PrimaryContainerColor">#D4E8FA</Color>
      <Color x:Key="OnPrimaryContainerColor">#002D5E</Color>
      <Color x:Key="SecondaryColor">#744DA9</Color>
      <Color x:Key="OnSecondaryColor">#FFFFFF</Color>
      <Color x:Key="SecondaryContainerColor">#ECDCFF</Color>
      <Color x:Key="OnSecondaryContainerColor">#2C0052</Color>
      <Color x:Key="TertiaryColor">#00809D</Color>
      <Color x:Key="OnTertiaryColor">#FFFFFF</Color>
      <Color x:Key="TertiaryContainerColor">#BBE9FF</Color>
      <Color x:Key="OnTertiaryContainerColor">#00344A</Color>
      <Color x:Key="ErrorColor">#C42B1C</Color>
      <Color x:Key="ErrorContainerColor">#FFD6D0</Color>
      <Color x:Key="OnErrorColor">#FFFFFF</Color>
      <Color x:Key="OnErrorContainerColor">#5A0000</Color>
      <Color x:Key="BackgroundColor">#F0EDE8</Color>
      <Color x:Key="OnBackgroundColor">#1A1A1A</Color>
      <Color x:Key="SurfaceColor">#F9F5FF</Color>
      <Color x:Key="OnSurfaceColor">#1A1A1A</Color>
      <Color x:Key="SurfaceVariantColor">#E8E0F0</Color>
      <Color x:Key="OnSurfaceVariantColor">#4A4458</Color>
      <Color x:Key="OutlineColor">#8F8A98</Color>
      <Color x:Key="OnSurfaceInverseColor">#F0EDE8</Color>
      <Color x:Key="SurfaceInverseColor">#2E2E36</Color>
      <Color x:Key="PrimaryInverseColor">#A0CAFF</Color>
      <Color x:Key="SurfaceTintColor">#005FB8</Color>
      <Color x:Key="OutlineVariantColor">#C4BED0</Color>

      <!-- No 3D bevel for Win11 — uses elevation/shadow instead -->
      <SolidColorBrush x:Key="Bevel3DHighlightBrush" Color="Transparent" />
      <SolidColorBrush x:Key="Bevel3DShadowBrush" Color="Transparent" />
    </ResourceDictionary>

    <ResourceDictionary x:Key="Dark">
      <Color x:Key="PrimaryColor">#005FB8</Color>
      <Color x:Key="OnPrimaryColor">#FFFFFF</Color>
      <Color x:Key="PrimaryContainerColor">#D4E8FA</Color>
      <Color x:Key="OnPrimaryContainerColor">#002D5E</Color>
      <Color x:Key="SecondaryColor">#744DA9</Color>
      <Color x:Key="OnSecondaryColor">#FFFFFF</Color>
      <Color x:Key="SecondaryContainerColor">#ECDCFF</Color>
      <Color x:Key="OnSecondaryContainerColor">#2C0052</Color>
      <Color x:Key="TertiaryColor">#00809D</Color>
      <Color x:Key="OnTertiaryColor">#FFFFFF</Color>
      <Color x:Key="TertiaryContainerColor">#BBE9FF</Color>
      <Color x:Key="OnTertiaryContainerColor">#00344A</Color>
      <Color x:Key="ErrorColor">#C42B1C</Color>
      <Color x:Key="ErrorContainerColor">#FFD6D0</Color>
      <Color x:Key="OnErrorColor">#FFFFFF</Color>
      <Color x:Key="OnErrorContainerColor">#5A0000</Color>
      <Color x:Key="BackgroundColor">#F0EDE8</Color>
      <Color x:Key="OnBackgroundColor">#1A1A1A</Color>
      <Color x:Key="SurfaceColor">#F9F5FF</Color>
      <Color x:Key="OnSurfaceColor">#1A1A1A</Color>
      <Color x:Key="SurfaceVariantColor">#E8E0F0</Color>
      <Color x:Key="OnSurfaceVariantColor">#4A4458</Color>
      <Color x:Key="OutlineColor">#8F8A98</Color>
      <Color x:Key="OnSurfaceInverseColor">#F0EDE8</Color>
      <Color x:Key="SurfaceInverseColor">#2E2E36</Color>
      <Color x:Key="PrimaryInverseColor">#A0CAFF</Color>
      <Color x:Key="SurfaceTintColor">#005FB8</Color>
      <Color x:Key="OutlineVariantColor">#C4BED0</Color>

      <SolidColorBrush x:Key="Bevel3DHighlightBrush" Color="Transparent" />
      <SolidColorBrush x:Key="Bevel3DShadowBrush" Color="Transparent" />
    </ResourceDictionary>

  </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
