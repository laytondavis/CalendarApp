<Page x:Class="CalendarApp.Presentation.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:CalendarApp.Presentation"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:um="using:Uno.Material"
      NavigationCacheMode="Required"
      Background="{ThemeResource BackgroundBrush}">

    <Grid utu:SafeArea.Insets="VisibleBounds">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top Navigation Bar -->
        <utu:NavigationBar Content="{Binding Title}" />

        <!-- Calendar Mode Selector -->
        <Grid Grid.Row="1" Padding="16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Calendar Mode Toggle -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <RadioButton Content="Gregorian"
                             GroupName="CalendarMode"
                             IsChecked="True"
                             Command="{Binding ChangeCalendarModeCommand}"
                             CommandParameter="0" />
                <RadioButton Content="Julian"
                             GroupName="CalendarMode"
                             Command="{Binding ChangeCalendarModeCommand}"
                             CommandParameter="1" />
                <RadioButton Content="Biblical"
                             GroupName="CalendarMode"
                             Command="{Binding ChangeCalendarModeCommand}"
                             CommandParameter="2" />
            </StackPanel>

            <!-- Today Button -->
            <Button Grid.Column="1"
                    Content="Today"
                    Command="{Binding TodayCommand}"
                    Style="{StaticResource FilledTonalButtonStyle}" />
        </Grid>

        <!-- Month Navigation Header -->
        <Grid Grid.Row="2" Padding="16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Command="{Binding PreviousCommand}"
                    Style="{StaticResource IconButtonStyle}">
                <FontIcon Glyph="&#xE76B;" FontSize="20" />
            </Button>

            <TextBlock Grid.Column="1"
                       Text="{Binding DisplayMonthYear}"
                       Style="{StaticResource TitleTextBlockStyle}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />

            <Button Grid.Column="2"
                    Command="{Binding NextCommand}"
                    Style="{StaticResource IconButtonStyle}">
                <FontIcon Glyph="&#xE76C;" FontSize="20" />
            </Button>
        </Grid>

        <!-- Calendar Grid -->
        <Grid Grid.Row="3" Padding="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Day of Week Headers -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Sun" HorizontalAlignment="Center"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock Grid.Column="1" Text="Mon" HorizontalAlignment="Center"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock Grid.Column="2" Text="Tue" HorizontalAlignment="Center"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock Grid.Column="3" Text="Wed" HorizontalAlignment="Center"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock Grid.Column="4" Text="Thu" HorizontalAlignment="Center"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock Grid.Column="5" Text="Fri" HorizontalAlignment="Center"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock Grid.Column="6" Text="Sat" HorizontalAlignment="Center"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </Grid>

            <!-- Calendar Days Grid -->
            <ItemsControl Grid.Row="1"
                          ItemsSource="{Binding MonthDays}"
                          Margin="0,8,0,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <utu:UniformGrid Columns="7" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="local:CalendarDayViewModel">
                        <Border BorderBrush="{ThemeResource DividerBrush}"
                                BorderThickness="0,0,1,1"
                                MinHeight="80"
                                Background="{ThemeResource SurfaceBrush}"
                                Padding="4">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <!-- Day Number with Today Indicator -->
                                <Grid HorizontalAlignment="Center">
                                    <Ellipse Width="28" Height="28"
                                             Fill="{ThemeResource PrimaryBrush}"
                                             Visibility="{x:Bind IsToday}" />
                                    <TextBlock Text="{x:Bind Day}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontWeight="{x:Bind IsToday, Converter={StaticResource BoolToFontWeightConverter}}"
                                               Foreground="{x:Bind IsToday, Converter={StaticResource BoolToForegroundConverter}}"
                                               Opacity="{x:Bind IsCurrentMonth, Converter={StaticResource BoolToOpacityConverter}}" />
                                </Grid>

                                <!-- Cross Reference (for Julian/Biblical) -->
                                <TextBlock Grid.Row="1"
                                           Text="{x:Bind CrossReference}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           Visibility="{x:Bind HasCrossReference}"
                                           FontSize="9"
                                           MaxLines="1" />

                                <!-- Events Preview -->
                                <ItemsControl Grid.Row="2"
                                              ItemsSource="{x:Bind Events}"
                                              Margin="0,4,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="local:CalendarEventViewModel">
                                            <Border Background="{ThemeResource PrimaryBrush}"
                                                    CornerRadius="2"
                                                    Padding="4,2"
                                                    Margin="0,1">
                                                <TextBlock Text="{x:Bind Title}"
                                                           Foreground="White"
                                                           FontSize="10"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxLines="1" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

        <!-- Bottom: Cross Reference Display -->
        <Border Grid.Row="4"
                Background="{ThemeResource SurfaceVariantBrush}"
                Padding="16,12"
                Visibility="{Binding CrossReferenceText, Converter={StaticResource NullToVisibilityConverter}}">
            <TextBlock Text="{Binding CrossReferenceText}"
                       Style="{StaticResource BodyTextBlockStyle}"
                       HorizontalAlignment="Center" />
        </Border>

        <!-- Loading Indicator -->
        <ProgressRing Grid.RowSpan="5"
                      IsActive="{Binding IsBusy}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Width="48"
                      Height="48" />
    </Grid>
</Page>
